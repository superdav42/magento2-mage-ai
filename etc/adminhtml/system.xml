<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="mageprince" translate="label" sortOrder="110" class="mageprince-tab">
            <label>Mageprince Extensions</label>
        </tab>
        <section id="mageai" translate="label" sortOrder="20" type="text" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Mage AI</label>
            <tab>mageprince</tab>
            <resource>Mageprince_MageAI::configuration</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1">
                <label>General</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="baseline_prompt" translate="label" type="textarea" sortOrder="20" showInDefault="1">
                    <label>Baseline Prompt</label>
                    <comment><![CDATA[Instructions automatically applied to every text generation request — Full Description, Short Description and Advanced Generate — across all providers. Use for brand voice, compliance requirements, SEO standards and content governance (e.g. "Use UK English. Maintain a professional tone. Avoid marketing hype."). Sent as the AI's system instruction, in addition to the built-in output-formatting rules. Leave empty to disable.]]></comment>
                </field>
            </group>
            <group id="api" translate="label" type="text" sortOrder="20" showInDefault="1">
                <label>API Configuration</label>
                <field id="provider" translate="label" type="select" sortOrder="10" showInDefault="1" canRestore="1">
                    <label>AI Provider</label>
                    <source_model>Mageprince\MageAI\Model\Config\Source\AIProvider</source_model>
                </field>
                <!-- OpenAI fields -->
                <field id="base_url" translate="label" type="text" sortOrder="20" showInDefault="1" showInStore="1" showInWebsite="1" canRestore="1">
                    <label>Base URL</label>
                    <comment>Use a custom OpenAI-compatible endpoint (e.g. a proxy). Leave default for api.openai.com.</comment>
                    <depends>
                        <field id="provider">openai</field>
                    </depends>
                </field>
                <field id="api_secret" translate="label" type="obscure" sortOrder="30" showInDefault="1">
                    <label>API Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[Generate API key from <a href="https://platform.openai.com/account/api-keys" target="_blank">platform.openai.com</a>]]></comment>
                    <depends>
                        <field id="provider">openai</field>
                    </depends>
                </field>
                <field id="model" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Model</label>
                    <comment><![CDATA[Check <a href="https://platform.openai.com/docs/models" target="_blank">OpenAI Models</a> for details]]></comment>
                    <source_model>Mageprince\MageAI\Model\Config\Source\AIModel</source_model>
                    <depends>
                        <field id="provider">openai</field>
                    </depends>
                </field>
                <field id="custom_model" translate="label" type="text" sortOrder="45" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Custom OpenAI-Compatible Model</label>
                    <comment>Optional. Enter a model ID from an OpenAI-compatible endpoint. When set, this overrides the selected OpenAI model.</comment>
                    <depends>
                        <field id="provider">openai</field>
                    </depends>
                </field>
                <!-- Anthropic (Claude) fields -->
                <field id="anthropic_base_url" translate="label" type="text" sortOrder="50" showInDefault="1" showInStore="1" showInWebsite="1" canRestore="1">
                    <label>Base URL</label>
                    <comment>Use a custom Anthropic-compatible endpoint. Leave default for api.anthropic.com.</comment>
                    <depends>
                        <field id="provider">anthropic</field>
                    </depends>
                </field>
                <field id="anthropic_api_secret" translate="label" type="obscure" sortOrder="60" showInDefault="1">
                    <label>API Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[Generate API key from <a href="https://console.anthropic.com/settings/keys" target="_blank">console.anthropic.com</a>]]></comment>
                    <depends>
                        <field id="provider">anthropic</field>
                    </depends>
                </field>
                <field id="anthropic_model" translate="label" type="select" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Model</label>
                    <comment><![CDATA[Check <a href="https://docs.anthropic.com/en/docs/about-claude/models" target="_blank">Anthropic Models</a> for details]]></comment>
                    <source_model>Mageprince\MageAI\Model\Config\Source\AnthropicModel</source_model>
                    <depends>
                        <field id="provider">anthropic</field>
                    </depends>
                </field>
                <!-- Google Gemini fields -->
                <field id="gemini_base_url" translate="label" type="text" sortOrder="80" showInDefault="1" showInStore="1" showInWebsite="1" canRestore="1">
                    <label>Base URL</label>
                    <comment>Use a custom Gemini-compatible endpoint. Leave default for generativelanguage.googleapis.com.</comment>
                    <depends>
                        <field id="provider">gemini</field>
                    </depends>
                </field>
                <field id="gemini_api_secret" translate="label" type="obscure" sortOrder="90" showInDefault="1">
                    <label>API Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[Generate API key from <a href="https://aistudio.google.com/apikey" target="_blank">Google AI Studio</a>]]></comment>
                    <depends>
                        <field id="provider">gemini</field>
                    </depends>
                </field>
                <field id="gemini_model" translate="label" type="select" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Model</label>
                    <comment><![CDATA[Check <a href="https://ai.google.dev/gemini-api/docs/models/gemini" target="_blank">Gemini Models</a> for details]]></comment>
                    <source_model>Mageprince\MageAI\Model\Config\Source\GeminiModel</source_model>
                    <depends>
                        <field id="provider">gemini</field>
                    </depends>
                </field>
            </group>
            <group id="product_description" translate="label" type="text" sortOrder="30" showInDefault="1">
                <label>Product Description Configuration</label>
                <field id="temperature" translate="label" type="text" sortOrder="10" showInDefault="1" canRestore="1">
                    <label>Temperature</label>
                    <comment>What sampling temperature to use, between 0 and 2. Higher values like 0.8 will make the output more random, while lower values like 0.2 will make it more focused and deterministic.</comment>
                    <validate>required-entry validate-number</validate>
                </field>
                <field id="attribute" translate="label" type="multiselect" sortOrder="20" showInDefault="1" canRestore="1">
                    <label>Content Based on Selected Product Attributes</label>
                    <comment>AI will use the values of the selected attributes to generate content.</comment>
                    <source_model>Mageprince\MageAI\Model\Config\Source\Attributes</source_model>
                </field>
                <field id="description_prompt" translate="label" type="textarea" sortOrder="30" showInDefault="1" showInStore="1" showInWebsite="1" canRestore="1">
                    <label>Full Description Prompt</label>
                    <comment><![CDATA[Available variables: <code>{{ product.name }}</code> — product name, <code>{{ product.attributes }}</code> — selected attribute label/value pairs.]]></comment>
                </field>
                <field id="description_max_tokens" translate="label" type="text" sortOrder="40" showInDefault="1" canRestore="1">
                    <label>Full Description Max Tokens</label>
                    <comment>Maximum number of tokens the AI may generate for the full description.</comment>
                    <validate>required-entry validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="short_description_prompt" translate="label" type="textarea" sortOrder="50" showInDefault="1" showInStore="1" showInWebsite="1" canRestore="1">
                    <label>Short Description Prompt</label>
                    <comment><![CDATA[Available variables: <code>{{ product.name }}</code> — product name, <code>{{ product.attributes }}</code> — selected attribute label/value pairs.]]></comment>
                </field>
                <field id="short_description_max_tokens" translate="label" type="text" sortOrder="60" showInDefault="1" canRestore="1">
                    <label>Short Description Max Tokens</label>
                    <comment>Maximum number of tokens the AI may generate for the short description.</comment>
                    <validate>required-entry validate-digits validate-greater-than-zero</validate>
                </field>
            </group>
            <group id="image_generation" translate="label" type="text" sortOrder="40" showInDefault="1">
                <label>Image Generation Configuration</label>
                <field id="default_prompt" translate="label" type="textarea" sortOrder="10" showInDefault="1" showInStore="1" showInWebsite="1" canRestore="1">
                    <label>Default Image Prompt</label>
                    <comment><![CDATA[Used when no custom prompt is entered in the modal. Available variables: <code>{{ product.name }}</code> — product name, <code>{{ product.attributes }}</code> — selected attribute label/value pairs. Both variables also work in the modal's custom prompt.]]></comment>
                </field>
                <field id="modify_default_prompt" translate="label" type="textarea" sortOrder="12" showInDefault="1" showInStore="1" showInWebsite="1" canRestore="1">
                    <label>Default Image Modify Prompt</label>
                    <comment><![CDATA[Used by "Modify Image with MageAI" when no custom prompt is entered. The original image is sent to the AI together with this instruction. Available variables: <code>{{ product.name }}</code> — product name, <code>{{ product.attributes }}</code> — selected attribute label/value pairs.]]></comment>
                </field>
                <field id="attribute" translate="label" type="multiselect" sortOrder="15" showInDefault="1" canRestore="1">
                    <label>Image Content Based on Selected Product Attributes</label>
                    <comment>Values of these attributes fill the <![CDATA[<code>{{ product.attributes }}</code>]]> variable in the image prompt. Independent from the description attribute selection. Tip: keep image prompts focused on visual details.</comment>
                    <source_model>Mageprince\MageAI\Model\Config\Source\Attributes</source_model>
                </field>
                <field id="openai_image_model" translate="label" type="select" sortOrder="20" showInDefault="1" canRestore="1">
                    <label>OpenAI Image Model</label>
                    <source_model>Mageprince\MageAI\Model\Config\Source\OpenAIImageModel</source_model>
                    <comment><![CDATA[Check <a href="https://platform.openai.com/docs/guides/image-generation" target="_blank">Image Generation Models</a> for details.]]></comment>
                    <depends>
                        <field id="mageai/api/provider">openai</field>
                    </depends>
                </field>
                <field id="gpt_image_size" translate="label" type="select" sortOrder="22" showInDefault="1" canRestore="1">
                    <label>Image Size</label>
                    <source_model>Mageprince\MageAI\Model\Config\Source\GptImageSize</source_model>
                    <comment>All GPT Image models support the same sizes. Square (1024×1024) is recommended for product photos. Smaller sizes generate faster.</comment>
                    <depends>
                        <field id="mageai/api/provider">openai</field>
                    </depends>
                </field>
                <field id="gpt_image_quality" translate="label" type="select" sortOrder="24" showInDefault="1" canRestore="1">
                    <label>Image Quality</label>
                    <source_model>Mageprince\MageAI\Model\Config\Source\ImageQuality</source_model>
                    <comment>Lower quality generates much faster. Use Low for quick drafts, High for final product images.</comment>
                    <depends>
                        <field id="mageai/api/provider">openai</field>
                    </depends>
                </field>
                <field id="gemini_image_model" translate="label" type="select" sortOrder="30" showInDefault="1" canRestore="1">
                    <label>Gemini Image Model</label>
                    <source_model>Mageprince\MageAI\Model\Config\Source\GeminiImageModel</source_model>
                    <comment><![CDATA[Check <a href="https://ai.google.dev/gemini-api/docs/image-generation" target="_blank">Gemini Image Generation</a> for available models.]]></comment>
                    <depends>
                        <field id="mageai/api/provider">gemini</field>
                    </depends>
                </field>
            </group>
            <group id="product_image_analysis" translate="label" type="text" sortOrder="50" showInDefault="1">
                <label>Product Image Analysis</label>
                <field id="prompt" translate="label" type="textarea" sortOrder="10" showInDefault="1" showInStore="1" showInWebsite="1" canRestore="1">
                    <label>Image Metadata Prompt</label>
                    <comment><![CDATA[Used by <code>bin/magento mageai:generate:image-metadata</code> and the admin product edit image-analysis button. The product's image is sent to the configured OpenAI-compatible chat completions endpoint. Attribute-specific JSON output instructions are built from the rows below.]]></comment>
                </field>
                <field id="max_tokens" translate="label" type="text" sortOrder="20" showInDefault="1" canRestore="1">
                    <label>Image Analysis Max Tokens</label>
                    <validate>required-entry validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="temperature" translate="label" type="text" sortOrder="30" showInDefault="1" canRestore="1">
                    <label>Image Analysis Temperature</label>
                    <comment>Sampling temperature for image analysis only. Use 0 for deterministic catalog metadata.</comment>
                    <validate>required-entry validate-number</validate>
                </field>
                <field id="attributes" translate="label" sortOrder="40" showInDefault="1" canRestore="1">
                    <label>Update These Attributes Based on Product Image Analysis</label>
                    <frontend_model>Mageprince\MageAI\Block\Adminhtml\System\Config\Form\Field\ImageAnalysisAttributes</frontend_model>
                    <backend_model>Magento\Config\Model\Config\Backend\Serialized\ArraySerialized</backend_model>
                    <comment><![CDATA[Add one row per safe product attribute to update. Supported inputs are text, textarea, select, and multiselect. The update policy controls whether MageAI fills only empty fields, replaces values, or merges keyword/tag-style multiselects. Enable "Create Options" only for tag-style select/multiselect attributes where AI may add missing options. Existing values for configured attributes are included as context, so empty SEO/title/description fields can be generated from populated values.]]></comment>
                </field>
            </group>
        </section>
    </system>
</config>
